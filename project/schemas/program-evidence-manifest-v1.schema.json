{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Pagebabe/comic/project/schemas/program-evidence-manifest-v1.schema.json",
  "title": "Comic Factory Program Evidence Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repository", "generated_at", "source_main", "program_status", "decision", "workers", "factory_integration", "merge_rehearsal", "growth_dependency", "blocked_gates", "release_rules", "activation_controls", "main_merge_allowed", "live_activation_allowed", "integrity"],
  "properties": {
    "schema_version": {"const": 1},
    "repository": {"const": "Pagebabe/comic"},
    "generated_at": {"type": "string", "format": "date-time"},
    "source_main": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "head_sha", "unchanged"],
      "properties": {
        "branch": {"const": "main"},
        "head_sha": {"$ref": "#/$defs/sha"},
        "unchanged": {"const": true}
      }
    },
    "program_status": {"const": "PROGRAM_FACTORY_INTEGRATION_PROVEN_MAIN_BLOCKED"},
    "decision": {"const": "PROGRAM_EVIDENCE_GATE_READY"},
    "workers": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/worker"}},
    "factory_integration": {"$ref": "#/$defs/factory_integration"},
    "merge_rehearsal": {"$ref": "#/$defs/merge_rehearsal"},
    "growth_dependency": {"$ref": "#/$defs/growth_dependency"},
    "blocked_gates": {"type": "array", "minItems": 7, "maxItems": 7, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "release_rules": {"type": "object", "minProperties": 8, "additionalProperties": {"const": true}},
    "activation_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["oauth_allowed", "platform_accounts_connected", "network_execution_allowed", "publishing_allowed"],
      "properties": {
        "oauth_allowed": {"const": false},
        "platform_accounts_connected": {"const": 0},
        "network_execution_allowed": {"const": false},
        "publishing_allowed": {"const": false}
      }
    },
    "main_merge_allowed": {"const": false},
    "live_activation_allowed": {"const": false},
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "manifest_sha256"],
      "properties": {
        "algorithm": {"const": "sha256"},
        "manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "pr": {
      "type": "object",
      "required": ["number", "state", "draft", "merged"],
      "properties": {
        "number": {"type": "integer", "minimum": 1},
        "state": {"enum": ["open", "closed"]},
        "draft": {"type": "boolean"},
        "merged": {"type": "boolean"},
        "base": {"type": "string"},
        "base_sha": {"$ref": "#/$defs/sha"},
        "head_sha": {"$ref": "#/$defs/sha"},
        "merge_commit_sha": {"$ref": "#/$defs/sha"},
        "merge_test_sha": {"$ref": "#/$defs/sha"}
      },
      "additionalProperties": false
    },
    "worker": {
      "type": "object",
      "required": ["worker_id", "role", "branch", "head_sha", "status", "pr", "merged_to_main", "non_claims"],
      "properties": {
        "worker_id": {"type": "integer", "minimum": 1, "maximum": 3},
        "role": {"type": "string"},
        "branch": {"type": "string"},
        "head_sha": {"$ref": "#/$defs/sha"},
        "status": {"type": "string"},
        "pr": {"$ref": "#/$defs/pr"},
        "technical_only": {"type": "boolean"},
        "real_pilot_proven": {"type": "boolean"},
        "merged_to_main": {"const": false},
        "non_claims": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow", "run_id", "artifact_id", "digest"],
      "properties": {
        "workflow": {"type": "string"},
        "run_id": {"type": "integer", "minimum": 1},
        "artifact_id": {"type": "integer", "minimum": 1},
        "digest": {"$ref": "#/$defs/digest"}
      }
    },
    "factory_integration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "head_sha", "status", "pr", "contains", "runs", "main_merge_allowed", "growth_included", "live_activation_allowed"],
      "properties": {
        "branch": {"const": "integration/factory-final-heads"},
        "head_sha": {"$ref": "#/$defs/sha"},
        "status": {"const": "FACTORY_INTEGRATION_PROVEN"},
        "pr": {"$ref": "#/$defs/pr"},
        "contains": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object", "required": ["worker_id", "merge_commit_sha"], "properties": {"worker_id": {"type": "integer"}, "merge_commit_sha": {"$ref": "#/$defs/sha"}}, "additionalProperties": false}},
        "runs": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"$ref": "#/$defs/run"}},
        "main_merge_allowed": {"const": false},
        "growth_included": {"const": false},
        "live_activation_allowed": {"const": false}
      }
    },
    "merge_rehearsal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pr", "head_sha", "status", "run_id", "artifact_id", "digest", "factory_workers_composable", "growth_conflict_path", "rollback_clean"],
      "properties": {
        "pr": {"const": 142},
        "head_sha": {"$ref": "#/$defs/sha"},
        "status": {"const": "PROGRAM_MERGE_REHEARSAL_READY_CURRENT_HEADS"},
        "run_id": {"type": "integer"},
        "artifact_id": {"type": "integer"},
        "digest": {"$ref": "#/$defs/digest"},
        "factory_workers_composable": {"const": true},
        "growth_conflict_path": {"const": "package.json"},
        "rollback_clean": {"const": true}
      }
    },
    "growth_dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mkt0_head_sha", "behind_main_by", "pr", "status", "conflict_path", "satisfied"],
      "properties": {
        "mkt0_head_sha": {"$ref": "#/$defs/sha"},
        "behind_main_by": {"const": 344},
        "pr": {"$ref": "#/$defs/pr"},
        "status": {"const": "CURRENT_MAIN_REINTEGRATION_REQUIRED"},
        "conflict_path": {"const": "package.json"},
        "satisfied": {"const": false}
      }
    }
  }
}
