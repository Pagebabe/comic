    "forbiddenElements": [
      "script",
      "iframe",
      "object",
      "embed",
      "form",
      "button",
      "input",
      "video",
      "audio"
    ],
    "forbiddenResourceSchemes": [
      "http:",
      "https:",
      "file:",
      "data:",
      "javascript:"
    ],
    "pathRenderingRule": "Every JSON record and exclusion sourcePath must appear as HTML-escaped visible text. No source path may be turned into a link or executable resource."
