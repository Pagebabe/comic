  "safety": {
    "reviewStatus": "REVIEW_REQUIRED",
    "sourceExecuted": false,
    "sourceCopied": false,
    "sourceImported": false,
    "automaticMasterApproval": false,
    "automaticMasterApprovals": 0,
    "outputMayContainSourceBytes": false,
    "outputMayContainBase64Media": false,
    "outputMayContainClickableFileLinks": false,
    "outputMayMutateSourceAssets": false
