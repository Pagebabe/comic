      "sourceSha256",
      "reason",
      "reviewStatus",
      "sourceExecuted",
      "sourceCopied",
      "sourceImported",
      "automaticMasterApproval"
    ],
    "ordering": {
      "records": "sourcePath ascending, Unicode code-point order",
      "exclusions": "sourcePath ascending, Unicode code-point order"
    },
    "fixtureExpectedSummary": {
      "inputRecords": 19,
      "includedRecords": 17,
      "excludedRecords": 2,
      "duplicateGroups": 1,
      "automaticMasterApprovals": 0,
      "sourceFilesExecuted": 0,
      "sourceFilesCopied": 0,
      "sourceFilesImported": 0,
      "defaultReviewStatus": "REVIEW_REQUIRED"
    }
  },
  "csv": {
    "encoding": "UTF-8",
    "lineEnding": "LF",
    "header": [
      "sourcePath",
      "sourceSha256",
      "assetClass",
      "sourceExtension",
      "legacyCharacterId",
      "canonicalCharacterId",
      "mappingStatus",
      "reviewStatus",
      "duplicateOf",
      "sourceExecuted",
      "sourceCopied",
      "sourceImported",
      "automaticMasterApproval"
    ],
    "rows": "exactly one row for every JSON records entry in identical order",
    "nullEncoding": "empty field",
    "booleanEncoding": ["true", "false"]
  },
  "html": {
    "documentType": "static review report",
    "language": "de",
    "requiredCsp": "default-src 'none'; style-src 'unsafe-inline'; img-src 'none'; font-src 'none'; connect-src 'none'; media-src 'none'; object-src 'none'; frame-src 'none'; base-uri 'none'; form-action 'none'",
    "requiredVisibleTokens": [
      "Legacy-Asset-Migrationsprüfung",
      "REVIEW_REQUIRED",
      "LEGACY_SUPPORT_UNMAPPED",
      "AUTOMATIC_MASTER_APPROVALS: 0",
      "19 Eingaben",
      "17 Prüfzeilen",
      "2 Ausschlüsse",
      "1 Duplikatgruppe"
