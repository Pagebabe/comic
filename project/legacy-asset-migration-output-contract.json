      "sourceSha256",
      "assetClass",
      "sourceExtension",
      "legacyCharacterId",
      "canonicalCharacterId",
      "mappingStatus",
      "reviewStatus",
      "duplicateOf",
      "sourceExecuted",
      "sourceCopied",
      "sourceImported",
      "automaticMasterApproval"
    ],
    "requiredExclusionFields": [
