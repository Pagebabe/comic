{
  "schemaVersion": 1,
  "contractId": "legacy-asset-migration-output-v1",
  "repository": "Pagebabe/comic",
  "trackingIssue": 125,
  "status": "OUTPUT_CONTRACT_DEFINED_REVIEW_REQUIRED",
  "purpose": "Define the deterministic, read-only JSON, CSV and static HTML outputs required from the legacy asset migration loader without importing, executing or approving any source asset.",
  "authoritativeInputs": [
