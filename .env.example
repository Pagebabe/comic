# Optional backend/API settings for the Comic Factory adapter layer.
# The app still works in local browser mode without these values.

# Supabase REST adapter
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ComfyUI browser adapter
# Example local URL: http://127.0.0.1:8188
VITE_COMFYUI_API_URL=
VITE_COMFYUI_CLIENT_ID=ricco_factory_browser
