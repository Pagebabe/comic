{
  "id": "comic_panel_clean_v1",
  "status": "locked_template_contract",
  "version": 1,
  "purpose": "Clean single comic panel render for the Rico gegen Berlin pilot.",
  "mode": "contract_first_graph_later",
  "notes": [
    "This file locks the workflow contract before real ComfyUI sending is enabled.",
    "It defines the required slots and the intended node targets.",
    "The actual exported ComfyUI graph must preserve these slot names."
  ],
  "required_slots": [
    "positive_prompt",
    "negative_prompt",
    "width",
    "height",
    "seed",
    "steps",
    "cfg",
    "sampler",
    "scheduler",
    "output_path"
  ],
  "slot_defaults": {
    "width": 1080,
    "height": 1350,
    "seed": -1,
    "steps": 30,
    "cfg": 4.5,
    "sampler": "dpmpp_2m",
    "scheduler": "karras"
  },
  "node_targets": {
    "positive_prompt": {
      "node_id": "positive_text_encode",
      "class_type": "CLIPTextEncode",
      "input": "text"
    },
    "negative_prompt": {
      "node_id": "negative_text_encode",
      "class_type": "CLIPTextEncode",
      "input": "text"
    },
    "width": {
      "node_id": "empty_latent_image",
      "class_type": "EmptyLatentImage",
      "input": "width"
    },
    "height": {
      "node_id": "empty_latent_image",
      "class_type": "EmptyLatentImage",
      "input": "height"
    },
    "seed": {
      "node_id": "ksampler",
      "class_type": "KSampler",
      "input": "seed"
    },
    "steps": {
      "node_id": "ksampler",
      "class_type": "KSampler",
      "input": "steps"
    },
    "cfg": {
      "node_id": "ksampler",
      "class_type": "KSampler",
      "input": "cfg"
    },
    "sampler": {
      "node_id": "ksampler",
      "class_type": "KSampler",
      "input": "sampler_name"
    },
    "scheduler": {
      "node_id": "ksampler",
      "class_type": "KSampler",
      "input": "scheduler"
    },
    "output_path": {
      "node_id": "save_image",
      "class_type": "SaveImage",
      "input": "filename_prefix"
    }
  },
  "graph_skeleton": [
    {
      "node_id": "checkpoint_loader",
      "class_type": "CheckpointLoaderSimple",
      "role": "load_base_model"
    },
    {
      "node_id": "positive_text_encode",
      "class_type": "CLIPTextEncode",
      "role": "encode_positive_prompt"
    },
    {
      "node_id": "negative_text_encode",
      "class_type": "CLIPTextEncode",
      "role": "encode_negative_prompt"
    },
    {
      "node_id": "empty_latent_image",
      "class_type": "EmptyLatentImage",
      "role": "create_panel_canvas"
    },
    {
      "node_id": "ksampler",
      "class_type": "KSampler",
      "role": "sample_image"
    },
    {
      "node_id": "vae_decode",
      "class_type": "VAEDecode",
      "role": "decode_image"
    },
    {
      "node_id": "save_image",
      "class_type": "SaveImage",
      "role": "write_panel_output"
    }
  ],
  "render_rules": [
    "Do not render speech bubbles.",
    "Do not render readable dialogue inside the image.",
    "Keep dialogue only as metadata for voice, subtitles or layout.",
    "Use clean comic composition with space for later lettering.",
    "Every render must return to review before approval."
  ],
  "review_required": true,
  "review_checks": [
    "character_consistency",
    "location_consistency",
    "clean_frame_no_text",
    "readable_composition",
    "face_and_hands_ok",
    "matches_panel_action"
  ],
  "locked_until_changed_by": "manual_review"
}
