{
  "name": "comic-factory",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3100",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3100",
    "test:e2e": "playwright test",
    "setup:outputs": "node scripts/setupOutputs.mjs",
    "create:keyframe-jobs": "node scripts/createKeyframeJobs.mjs",
    "create:repair-jobs": "node scripts/createRepairJobs.mjs",
    "create:review-manifests": "node scripts/createReviewManifests.mjs",
    "create:assembly-package": "node scripts/createAssemblyPackage.mjs",
    "create:voice-package": "node scripts/createVoicePackage.mjs",
    "create:sound-package": "node scripts/createSoundPackage.mjs",
    "create:remotion-plan": "node scripts/createRemotionPlan.mjs",
    "create:comfy-batch": "node scripts/createComfyBatch.mjs",
    "comfy:dry-run": "node scripts/comfyRunnerDryRun.mjs",
    "comfy:check-preview": "node scripts/checkComfyPreview.mjs",
    "create:asset-intake": "node scripts/createAssetIntake.mjs",
    "sync:asset-previews": "node scripts/syncAssetPreviews.mjs",
    "create:pipeline-overview": "node scripts/createPipelineOverview.mjs",
    "create:review-summary": "node scripts/createReviewSummary.mjs",
    "create:next-shot-brief": "node scripts/createNextShotBrief.mjs",
    "create:shot-brief-pack": "node scripts/createShotBriefPack.mjs",
    "create:prompt-files": "node scripts/createPromptFiles.mjs",
    "create:motion-jobs": "node scripts/createMotionJobs.mjs",
    "create:camera-notes": "node scripts/createMotionTextFiles.mjs",
    "place:keyframe": "node scripts/placeKeyframe.mjs",
    "check:pilot-ready": "node scripts/checkAssemblyGate.mjs",
    "review:set": "node scripts/updateReviewDecision.mjs",
    "prepare:pilot": "node scripts/preparePilotProduction.mjs",
    "assemble:pilot": "node scripts/assemblePilot.mjs"
